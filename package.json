{
  "name": "backbenchers-portal",
  "version": "1.0.0",
  "description": "Student notes and papers sharing portal",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "build": "npm run build --prefix frontend",
    "install-all": "npm install && npm install --prefix frontend",
    "postinstall": "npm install --prefix frontend"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
